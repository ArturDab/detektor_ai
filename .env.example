# Skopiuj do .env i uzupelnij. Plik .env jest ignorowany przez git.

# Klucz do Google Gemini API (Google AI Studio). Bez niego narzedzie
# dziala w trybie "tylko heurystyki".
GEMINI_API_KEY=

# Model uzywany jako sedzia LLM. Domyslnie Gemini 3.1 Pro.
GEMINI_MODEL=gemini-3.1-pro-preview

# Wlacz/wylacz warstwe LLM (true/false).
ENABLE_LLM=true

# Uzyj spaCy (pl_core_news_sm) zamiast lekkiego segmentera regex.
# Wymaga instalacji extras: pip install -e ".[nlp]" oraz modelu.
USE_SPACY=false

# Timeout pojedynczego wywolania LLM (sekundy).
LLM_TIMEOUT_S=20

# Udzial oceny LLM w finalnym wskazniku (reszta to heurystyki).
LLM_BLEND_SLOP=0.5
LLM_BLEND_AI=0.6
